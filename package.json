{
  "name": "cowork---virtual-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p ./tsconfig.app.json --noEmit",
    "validar": "npm run typecheck && npm run build",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "test": "npx playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:smoke": "npx playwright test --project=smoke",
    "test:e2e": "npx playwright test --project=e2e",
    "test:funcional": "npx playwright test --project=funcional",
    "test:regresion": "npx playwright test --project=regresion",
    "test:caja-negra": "npx playwright test --project=caja-negra",
    "test:mobile": "npx playwright test --project=mobile",
    "test:all": "npx playwright test --project=smoke --project=e2e --project=funcional --project=regresion --project=caja-negra",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:report": "npx playwright show-report",
    "test:seed": "node tests/scripts/seed-test-users.mjs",
    "assets:premerge-keyboard": "node --env-file=.env scripts/assets/premerge-glb.mjs --input Keyboard.glb --output Keyboard.merged.glb",
    "assets:premerge-keyboard:dry": "node --env-file=.env scripts/assets/premerge-glb.mjs --input Keyboard.glb --output Keyboard.merged.glb --dry-run",
    "assets:premerge-computer": "node --env-file=.env scripts/assets/premerge-glb.mjs --input \"Simple computer.glb\" --output \"Simple computer.merged.glb\"",
    "assets:premerge-computer:dry": "node --env-file=.env scripts/assets/premerge-glb.mjs --input \"Simple computer.glb\" --output \"Simple computer.merged.glb\" --dry-run",
    "assets:premerge-desk": "node --env-file=.env scripts/assets/premerge-glb.mjs --input \"Adjustable Desk.glb\" --output \"Adjustable Desk.merged.glb\"",
    "assets:premerge-desk:dry": "node --env-file=.env scripts/assets/premerge-glb.mjs --input \"Adjustable Desk.glb\" --output \"Adjustable Desk.merged.glb\" --dry-run",
    "assets:verify-drift": "node --env-file=.env scripts/assets/verify-drift.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@livekit/components-react": "^2.9.19",
    "@livekit/components-styles": "^1.2.0",
    "@livekit/track-processors": "^0.7.2",
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/drawing_utils": "^0.3.1675466124",
    "@mediapipe/hands": "^0.4.1675469240",
    "@mediapipe/selfie_segmentation": "^0.1.1675465747",
    "@mediapipe/tasks-vision": "^0.10.33",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/rapier": "^2.2.0",
    "@sentry/react": "^10.47.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@supabase/supabase-js": "^2.47.10",
    "@types/three": "^0.182.0",
    "bitecs": "^0.4.0",
    "chess.js": "^1.4.0",
    "driver.js": "^1.4.0",
    "framer-motion": "^11.15.0",
    "i18next": "^25.8.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "livekit-client": "^2.17.0",
    "lucide-react": "^0.468.0",
    "phaser": "3.80.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.4",
    "three": "^0.182.0",
    "three-mesh-bvh": "^0.9.9",
    "three-stdlib": "^2.36.1",
    "uuid": "^13.0.0",
    "zustand": "^5.0.9"
  },
  "overrides": {
    "@dimforge/rapier3d-compat": "0.19.3"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  }
}
