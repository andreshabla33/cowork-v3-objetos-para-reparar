# Plantilla para stress test harness.
#
# USO:
#   1. Copiá este archivo como `.env.stress.local` (gitignored).
#   2. Completá los valores.
#   3. Ejecutá `npm run stress:fase1` o `npm run stress:all`.
#
# Los runners auto-cargan `.env.stress.local` desde la raíz del repo
# — no necesitás exportar manualmente en shell.

# ────────────── Fase 1 (renderer local, cost $0) ──────────────
FASE1_BASE_URL=http://localhost:5173
FASE1_LOGIN_EMAIL=am@urpeailab.com
FASE1_LOGIN_PASSWORD=tu-password-aqui
# Opcionales:
# FASE1_DURATION_SEC=300
# FASE1_WARMUP_SEC=5
# FASE1_HEADLESS=false

# ────────────── Fase 2 (SFU load-test via lk CLI) ──────────────
# LIVEKIT_URL=wss://tu-proyecto.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# ────────────── Fase 3 (E2E Playwright + fake media) ──────────────
# E2E_BASE_URL=http://localhost:5173
# E2E_CONCURRENCY=5
# E2E_TOTAL_JOURNEYS=10
# E2E_HEADLESS=true
# E2E_PROFILE=desktop

# ────────────── Orquestador ──────────────
# RUN_PHASES=1          # default — solo fase 1
# RUN_PHASES=1,2,3      # corre todas
# SKIP_GATE=true        # (debug) no aborta si una fase falla
